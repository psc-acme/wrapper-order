{
    "name": "psc-acme/wrapper-order",
    "description": "Package wrapper-order for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\WrapperOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "symfony/http-foundation": "^7.0",
        "symfony/yaml": "^7.0",
        "illuminate/support": "^11.0",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}